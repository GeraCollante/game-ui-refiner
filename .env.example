# game-ui-refiner environment variables
# Copy this file to .env and fill in your keys.
# serve.py reads these and injects them as window globals at runtime.

# Get a free Gemini API key at https://aistudio.google.com/app/apikey
# Free tier: 15 RPM / 1000 RPD on gemini-2.5-flash
GEMINI_API_KEY=AIza...

# Optional: only needed if you switch the provider to OpenRouter
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
